PORT=4000
MONGODB_URI=mongodb://localhost:27017/natura
JWT_SECRET=your-super-secret-jwt-key-change-in-production
NODE_ENV=development
# Firebase push (use one; do not commit the JSON file or the JSON string to Git):
# - Local: path to service account JSON file (relative to backend/ or absolute)
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# - Hosting (e.g. Render/Heroku): paste the entire JSON as one line (minified) in the host's env vars
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
